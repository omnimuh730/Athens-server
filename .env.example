# lancer-backend (copy to `.env` in this folder)
PORT=7979
# Listen on all interfaces so LAN clients (e.g. http://192.168.x.x:7979/api) can reach Node.
# Use HOST=127.0.0.1 if you only want local access.
HOST=0.0.0.0

# MongoDB (required) — primary database for reads and most collections
MONGO_URL=mongodb://127.0.0.1:27017
MONGO_DB=AIMS_local

# Cloud MongoDB — account_info writes are mirrored here; Vendor Monitor reads bid_records from cloud.
MONGO_CLOUD_URL=mongodb+srv://user:password@cluster.mongodb.net/

# Socket.IO CORS (comma-separated origins, or * for dev / Chrome extension)
# SOCKET_CORS_ORIGINS=*

# Neo4j skill knowledge graph
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=skillgraph-dev
# Set to true to fail startup when Neo4j is unreachable
# NEO4J_REQUIRED=false

# Skill graph analysis — DeepSeek only
# API key: account_info.autoBidProfile.deepseekApiKey (MongoDB, per applier profile)
# Model: deepseek-v4-flash (fixed)
# SKILL_GRAPH_ENRICHMENT_ENABLED=true
# SKILL_GRAPH_ENRICHMENT_MODE=fast
# fast = heuristic only ($0); smart = LLM for ambiguous skills only
# SKILL_GRAPH_ENRICH_CONCURRENCY=10
# SKILL_GRAPH_FUZZY_ALIAS_THRESHOLD=0.85
# SKILL_GRAPH_WORKER_INTERVAL_MS=5000
# SKILL_GRAPH_JOB_ANALYSIS_BATCH_SIZE=2
# SKILL_COOC_THRESHOLD=3

# Qdrant vector store (job + resume embeddings for recommendations)
QDRANT_URL=http://127.0.0.1:6333
# QDRANT_API_KEY=

# Embeddings — Ollama (default, free, no API key)
EMBEDDING_PROVIDER=ollama
OLLAMA_URL=http://127.0.0.1:11434
EMBEDDING_MODEL=mxbai-embed-large
EMBEDDING_DIMENSIONS=1024
# mxbai-embed-large max ~512 tokens; keep input under this char limit
# EMBEDDING_MAX_INPUT_CHARS=1800
# RECOMMENDATION_VECTOR_TOP_K=200
# RECOMMENDATION_CANDIDATE_POOL=500
#
# First-time setup:
#   docker compose up -d ollama
#   docker compose exec ollama ollama pull mxbai-embed-large
#   npm run backfill-job-embeddings && npm run backfill-resume-embeddings
#
# Optional OpenAI embeddings (requires autoBidProfile.openaiApiKey):
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536

# Mail sync (Gmail IMAP/SMTP — credentials per applier in account_info.autoBidProfile)
# MAIL_INITIAL_SYNC_SIZE=250
# MAIL_PAGE_LOAD_LIMIT=100
# MAIL_SYNC_MIN_INTERVAL_MS=45000
# MAIL_OLDER_BATCH_SIZE=50
